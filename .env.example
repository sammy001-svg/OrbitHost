; ─────────────────────────────────────────────────────────────
;  Orbit Cloud — Environment Configuration
;  Copy this file to your server root and fill in your values.
;  IMPORTANT: This file must NOT be publicly accessible.
;  On cPanel the project root should be ABOVE public_html, or
;  protect this file with the .htaccess rule already in place.
; ─────────────────────────────────────────────────────────────

; ── Database ──────────────────────────────────────────────────
; cPanel database names and usernames are prefixed with your
; cPanel account name, e.g. "cpanelusername_orbitcloud"
DB_HOST    = localhost
DB_NAME    = cpanelusername_orbitcloud
DB_USER    = cpanelusername_dbuser
DB_PASS    = your_database_password_here
DB_CHARSET = utf8mb4

; ── Application ───────────────────────────────────────────────
APP_NAME        = Orbit Cloud Admin
TAX_RATE        = 16
CURRENCY        = USD
PER_PAGE        = 20
SESSION_TIMEOUT = 7200

; ── Admin Panel URL ───────────────────────────────────────────
; Set this to the full URL of the /admin directory — NO trailing slash.
; Examples:
;   Local XAMPP:  http://localhost/OrbitHost/admin
;   cPanel live:  https://orbitcloud.co.ke/admin
; Leave commented out to use auto-detection (may fail on some servers).
; REQUIRED if you use the reminders cron job below — cron runs with no
; HTTP request to auto-detect from, so APP_URL must be set explicitly
; or every link in reminder/notification emails will point to localhost.
; APP_URL = http://localhost/OrbitHost/admin

; ── Scheduled reminders (admin/cron/reminders.php) ────────────
; Only needed if your host's cron can't run `php file.php` directly and
; must instead hit a URL (curl/wget). Set a long random value here, then
; point cron at: https://yourdomain.com/admin/cron/reminders.php?token=THIS_VALUE
; Leave blank/commented to only allow the script via CLI (recommended).
; CRON_SECRET = change-this-to-a-long-random-string
