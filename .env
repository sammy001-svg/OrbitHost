; ─────────────────────────────────────────────────────────────
;  OrbitHost — Environment Configuration
;  Copy this file to your server root and fill in your values.
;  IMPORTANT: This file must NOT be publicly accessible.
;  On cPanel the project root should be ABOVE public_html, or
;  protect this file with the .htaccess rule already in place.
; ─────────────────────────────────────────────────────────────

; ── Database ──────────────────────────────────────────────────
; cPanel database names and usernames are prefixed with your
; cPanel account name, e.g. "cpanelusername_orbithost"
DB_HOST    = localhost
DB_NAME    = cpanelusername_orbithost
DB_USER    = cpanelusername_dbuser
DB_PASS    = your_database_password_here
DB_CHARSET = utf8mb4

; ── Application ───────────────────────────────────────────────
APP_NAME        = OrbitHost Admin
TAX_RATE        = 16
CURRENCY        = USD
PER_PAGE        = 20
SESSION_TIMEOUT = 7200

; ── Admin Panel URL ───────────────────────────────────────────
; Set this to the full URL of the /admin directory — NO trailing slash.
; Examples:
;   Local XAMPP:  http://localhost/OrbitHost/admin
;   cPanel live:  https://orbithost.co.ke/admin
; Leave commented out to use auto-detection (may fail on some servers).
; APP_URL = http://localhost/OrbitHost/admin
