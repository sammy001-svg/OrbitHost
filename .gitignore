# Temporary and local IDE configurations
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Environment config — holds real DB credentials/URLs per-server.
# Never track this; copy .env.example instead. See .env.example for setup.
.env

# Admin-uploaded content (banner images etc.) — lives on the server, not in git
uploads/

# Automated DB backups (admin/cron/backup.php) — contains live customer
# data and credentials; never belongs in git regardless of the .htaccess
# deny-all the cron also writes into this directory on the server.
backups/
